# ProteoMind-AI Environment Configuration

# Directory containing your input CSVs (upregulated_proteins.csv and downregulated_proteins.csv)
# Default is ./input relative to main.py
# PROTEOMIND_INPUT_DIR=./input

# Directory where output files will be written
# Default is ./output relative to main.py
# PROTEOMIND_OUTPUT_DIR=./output

# Path to the Gemini Science Plugins directory
# This is required for the Reactome, HPA, and STRING API scripts.
# Default is ~/.gemini/config/plugins/science
# SCIENCE_PLUGINS_DIR=/path/to/your/science/plugins
